{
  "name": "fieldtrack-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "migrate": "drizzle-kit push",
    "migrate:generate": "drizzle-kit generate",
    "migrate:run": "ts-node src/db/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "ts-node src/db/seed.ts",
    "seed:streets": "ts-node src/db/seed-streets.ts",
    "deploy": "npm run build && npm run migrate:run && npm run start:pm2"
  },
  "dependencies": {
    "@supabase/storage-js": "^2.109.0",
    "@turf/turf": "^7.3.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.41.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "multer": "^1.4.5-lts.1",
    "postgres": "^3.4.4",
    "socket.io": "^4.7.5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "drizzle-kit": "^0.30.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
