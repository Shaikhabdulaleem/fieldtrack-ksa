# FieldTrack KSA — Backend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
# WHERE TO GET IT:
#   Supabase Dashboard → Settings → Database → Connection string → URI tab
#   Replace [YOUR-PASSWORD] with the password set during project creation.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Auth ────────────────────────────────────────────────────────────────────
# WHERE TO GET IT: Generate with → openssl rand -hex 64
# Must be at least 32 characters. Changing this invalidates ALL existing tokens.
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS ────────────────────────────────────────────────────────────────────
# WHERE TO GET IT: Your deployed frontend URL.
# PRODUCTION: set to your real frontend domain, e.g. https://app.fieldtrack.sa
FRONTEND_URL=http://localhost:5173

# ── Environment ─────────────────────────────────────────────────────────────
# Allowed values: development | production | test
NODE_ENV=development

# ── Supabase Storage ─────────────────────────────────────────────────────────
# WHERE TO GET THESE:
#   1. Go to https://supabase.com → open your project
#   2. Left sidebar → Settings → API
#   3. SUPABASE_URL        = "Project URL" (e.g. https://abcdef.supabase.co)
#   4. SUPABASE_SERVICE_KEY = "Project API keys" → service_role key
#      ⚠️  This key bypasses Row Level Security — never expose it in the frontend
#
# BUCKET SETUP:
#   1. Left sidebar → Storage → New bucket
#   2. Name: fieldtrack-uploads
#   3. Toggle "Public bucket" → ON (so photo URLs work without auth)
#   4. Click Create bucket
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY-HERE
SUPABASE_STORAGE_BUCKET=fieldtrack-uploads
